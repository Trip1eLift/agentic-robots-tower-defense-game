text = "[color=#e6c84a]move[/color] -- Go to a named position
[color=#e64a4a]attack[/color] -- Melee attack nearby enemy
[color=#e6a04a]snipe[/color] -- Ranged attack on distant target
[color=#4ae66a]heal[/color] -- Restore ally HP (medic)
[color=#4a9ee6]build[/color] -- Place fortification (architect)
[color=#aaaaaa]retreat[/color] -- Fall back to safety"
